<div class="faq-wrap" id="faq">
  <div class="faq-inner">
    <div class="section-header text-center mb-3">
      <span class="section-tag"><i class="fa-solid fa-circle-question"></i> {{ section.settings.tag }}</span>
      <h2 class="section-title">{{ section.settings.title }}<br><span class="text-green">{{ section.settings.title_accent }}</span></h2>
    </div>
    <div style="margin-top:2rem">
      {% for block in section.blocks %}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <button class="faq-q" onclick="toggleFaq(this)">
            {{ block.settings.question }}
            <i class="fa-solid fa-chevron-down"></i>
          </button>
          <div class="faq-a">{{ block.settings.answer }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "tag", "label": "Etiqueta", "default": "FAQ" },
    { "type": "text", "id": "title", "label": "Título", "default": "Preguntas" },
    { "type": "text", "id": "title_accent", "label": "Acento", "default": "Frecuentes" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Pregunta",
      "settings": [
        { "type": "text", "id": "question", "label": "Pregunta", "default": "¿Cuánto tiempo tarda el envío?" },
        { "type": "textarea", "id": "answer", "label": "Respuesta", "default": "Enviamos en 24-48 horas hábiles a todas las ciudades de Colombia." }
      ]
    }
  ],
  "presets": [{
    "name": "FAQ",
    "blocks": [
      { "type": "question", "settings": { "question": "¿Cuánto tiempo tarda el envío?", "answer": "Enviamos en 24-48 horas hábiles a todas las ciudades de Colombia. El envío es gratis en compras mayores a $150.000 COP." } },
      { "type": "question", "settings": { "question": "¿Los productos son originales y certificados?", "answer": "Sí, todos nuestros suplementos cuentan con registro INVIMA y cumplen con todas las normas sanitarias colombianas." } },
      { "type": "question", "settings": { "question": "¿Tienen garantía de satisfacción?", "answer": "Ofrecemos 30 días de garantía. Si no estás satisfecho, te devolvemos el dinero o hacemos un cambio sin costo adicional." } },
      { "type": "question", "settings": { "question": "¿Cómo puedo contactarlos?", "answer": "Puedes escribirnos por WhatsApp al +57 315 689 2441 las 24 horas. También respondemos en Instagram y por email." } }
    ]
  }]
}
{% endschema %}

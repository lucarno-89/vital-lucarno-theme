<div class="testimonials-wrap" id="testimonios">
  <div class="testimonials-inner">
    <div class="section-header text-center mb-3">
      <span class="section-tag"><i class="fa-solid fa-star"></i> {{ section.settings.tag }}</span>
      <h2 class="section-title">{{ section.settings.title }}<br><span class="text-green">{{ section.settings.title_accent }}</span></h2>
    </div>
    <div class="testimonials-grid">
      {% for block in section.blocks %}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="stars">★★★★★</div>
          <p class="testimonial-text">"{{ block.settings.quote }}"</p>
          <div class="testimonial-author">
            <div class="author-avatar">{{ block.settings.name | slice: 0, 2 | upcase }}</div>
            <div>
              <div class="author-name">{{ block.settings.name }}</div>
              <div class="author-city">{{ block.settings.city }}</div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Testimonios",
  "settings": [
    { "type": "text", "id": "tag", "label": "Etiqueta", "default": "Testimonios" },
    { "type": "text", "id": "title", "label": "Título", "default": "Lo que Dicen" },
    { "type": "text", "id": "title_accent", "label": "Acento", "default": "Nuestros Clientes" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Reseña",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Opinión", "default": "Excelentes productos, los resultados hablan por sí solos." },
        { "type": "text", "id": "name", "label": "Nombre", "default": "Juan Pérez" },
        { "type": "text", "id": "city", "label": "Ciudad", "default": "Bogotá, D.C." }
      ]
    }
  ],
  "presets": [{
    "name": "Testimonios",
    "blocks": [
      { "type": "review", "settings": { "quote": "Llevo 3 meses usando el Whey Pro Complex y los resultados son increíbles. Gané 4kg de músculo y la recuperación es mucho más rápida.", "name": "Juan Manuel R.", "city": "Medellín, Antioquia" } },
      { "type": "review", "settings": { "quote": "El pre-entreno X-Force es una locura. Energía brutal desde el primer minuto. Ya no puedo entrenar sin él.", "name": "Sara Alejandra V.", "city": "Bogotá, D.C." } },
      { "type": "review", "settings": { "quote": "Excelente calidad y precio justo. Los suplementos llegan bien empacados y el servicio al cliente es muy ágil. 100% recomendado.", "name": "Carlos P.", "city": "Cali, Valle del Cauca" } }
    ]
  }]
}
{% endschema %}
